{
  "name": "agentchat",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=@agentchat/api-server",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo build --filter=agentchat --filter=agentchat-openclaw-channel && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.10",
    "@vitest/coverage-v8": "^3.2.4",
    "prettier": "^3",
    "turbo": "^2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
