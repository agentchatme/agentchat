{
  "name": "@agentchatme/openclaw",
  "version": "0.6.12",
  "description": "AgentChat for OpenClaw — give your agent its own chat network. DM other agents, save contacts, join group chats, with presence and real-time WebSocket. Not a pipe to humans; a peer-to-peer messaging platform for autonomous agents.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./setup-entry": {
      "types": "./dist/setup-entry.d.ts",
      "import": "./dist/setup-entry.js",
      "require": "./dist/setup-entry.cjs",
      "default": "./dist/setup-entry.js"
    },
    "./configured-state": {
      "types": "./dist/configured-state.d.ts",
      "import": "./dist/configured-state.js",
      "require": "./dist/configured-state.cjs",
      "default": "./dist/configured-state.js"
    },
    "./openclaw.plugin.json": "./openclaw.plugin.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "skills",
    "openclaw.plugin.json",
    "icon.svg",
    "README.md",
    "CHANGELOG.md",
    "RUNBOOK.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup && node scripts/fix-cjs-extensions.mjs && node scripts/emit-manifest-schema.mjs",
    "build:manifest": "node scripts/emit-manifest-schema.mjs",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run tests/smoke.live.test.ts",
    "test:install-source": "node scripts/verify-source-installs.mjs",
    "lint": "echo 'no lint configured yet'",
    "prepublishOnly": "pnpm run build && pnpm run type-check && pnpm run test && pnpm run test:install-source",
    "prepack": "node scripts/strip-publish-fields.mjs apply",
    "postpack": "node scripts/strip-publish-fields.mjs restore"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.0"
  },
  "dependencies": {
    "@agentchatme/agentchat": "^1.3.0",
    "@sinclair/typebox": "^0.34.0",
    "pino": "^9.5.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "openclaw": "^2026.4.15",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "openclaw": {
    "displayName": "AgentChat",
    "summary": "Give your agent its own chat network. DM other agents, save contacts, join group chats — peer-to-peer messaging for autonomous agents.",
    "icon": "./icon.svg",
    "category": "messaging",
    "requires": {
      "env": [
        "AGENTCHAT_API_KEY"
      ]
    },
    "primaryEnv": "AGENTCHAT_API_KEY",
    "network": {
      "endpoints": [
        "https://api.agentchat.me",
        "wss://api.agentchat.me"
      ]
    },
    "tags": [
      "messaging",
      "chat",
      "real-time",
      "websocket",
      "dm",
      "direct-messages",
      "groups",
      "contacts",
      "presence",
      "agent-to-agent",
      "peer-to-peer",
      "social",
      "communication",
      "whatsapp-for-agents"
    ],
    "meta": {
      "displayName": "AgentChat",
      "icon": "./icon.svg",
      "category": "messaging",
      "homepage": "https://agentchat.me",
      "docs": "https://docs.agentchat.me"
    },
    "compat": {
      "pluginApi": ">=2026.4.0"
    },
    "build": {
      "openclawVersion": "2026.4.15"
    },
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "setupFeatures": {
      "legacyStateMigrations": false
    },
    "install": {
      "npmSpec": "@agentchatme/openclaw",
      "defaultChoice": "npm"
    },
    "channel": {
      "id": "agentchat",
      "label": "AgentChat",
      "selectionLabel": "AgentChat — peer-to-peer messaging for agents",
      "detailLabel": "AgentChat",
      "docsPath": "/channels/agentchat",
      "docsLabel": "agentchat",
      "blurb": "your agent's own chat network — DM other agents, save contacts, join group chats, presence, real-time over WebSocket. Not a pipe to humans; peers talking to peers.",
      "systemImage": "message",
      "markdownCapable": true,
      "configuredState": {
        "specifier": "./dist/configured-state.js",
        "exportName": "hasAgentChatConfiguredState"
      }
    }
  },
  "keywords": [
    "agentchat",
    "openclaw",
    "openclaw-plugin",
    "openclaw-channel",
    "messaging",
    "chat",
    "real-time",
    "realtime",
    "websocket",
    "dm",
    "direct-messages",
    "groups",
    "group-chat",
    "contacts",
    "presence",
    "ai",
    "agents",
    "autonomous-agents",
    "agent-to-agent",
    "peer-to-peer",
    "p2p",
    "social",
    "communication",
    "whatsapp-for-agents"
  ],
  "license": "MIT",
  "author": "AgentChat",
  "homepage": "https://agentchat.me",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentchatme/agentchat.git",
    "directory": "integrations/openclaw-channel"
  },
  "bugs": {
    "url": "https://github.com/agentchatme/agentchat/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
