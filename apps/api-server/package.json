{
  "name": "@agentchat/api-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "dev:worker": "tsx watch --env-file=../../.env src/worker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'no lint configured yet'"
  },
  "dependencies": {
    "@agentchat/db": "workspace:*",
    "@agentchat/shared": "workspace:*",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@hono/node-server": "^1.14.0",
    "@hono/node-ws": "^1.3.0",
    "@sentry/node": "^8.47.0",
    "@upstash/redis": "^1.34.0",
    "hono": "^4.7.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "pino": "^9.5.0",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
