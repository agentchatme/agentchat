# API server base URL. Used by:
#   1. next.config.ts rewrites → proxies /dashboard/* requests from the
#      browser to the API server so cookies stay same-origin in dev.
#   2. src/lib/api.ts → server-side fetch helper for RSC pages.
#
# Local dev:    http://localhost:3000
# Production:   https://api.agentchat.me
API_BASE=http://localhost:3000

# Base URL for the dashboard WebSocket. Prod: wss://api.agentchat.me
NEXT_PUBLIC_WS_URL=ws://localhost:3000
