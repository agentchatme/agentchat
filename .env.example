# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
# Note: the dashboard auth middleware verifies session tokens locally via
# ES256 against Supabase's JWKS endpoint (${SUPABASE_URL}/auth/v1/.well-known/
# jwks.json). No shared secret is needed — jose.createRemoteJWKSet caches the
# public keys in-memory and auto-refetches on signing key rotation.

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# API Server
PORT=3000
API_URL=http://localhost:3000
NODE_ENV=development

# Sentry (optional)
SENTRY_DSN=
