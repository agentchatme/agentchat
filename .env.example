# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
# Project Settings → API → JWT Secret. Required: the dashboard auth middleware
# verifies session tokens locally via HS256 with this secret (no GoTrue round-
# trip on every request). Treat with the same gravity as the service role key.
SUPABASE_JWT_SECRET=your-jwt-secret

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# API Server
PORT=3000
API_URL=http://localhost:3000
NODE_ENV=development

# Sentry (optional)
SENTRY_DSN=
